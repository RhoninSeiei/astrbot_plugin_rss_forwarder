{
  "feeds": {
    "type": "template_list",
    "description": "RSS 源配置",
    "templates": {
      "feed": {
        "name": "RSS 源",
        "hint": "配置一个 RSS/Atom 源",
        "items": {
          "id": {
            "type": "string",
            "default": "",
            "description": "Feed 唯一 ID"
          },
          "url": {
            "type": "string",
            "default": "",
            "description": "RSS/Atom 源地址"
          },
          "auth_mode": {
            "type": "string",
            "default": "none",
            "options": [
              "none",
              "query",
              "header"
            ],
            "description": "鉴权模式"
          },
          "key": {
            "type": "string",
            "default": "",
            "description": "query/header 使用的鉴权密钥"
          },
          "enabled": {
            "type": "bool",
            "default": true,
            "description": "是否启用该源"
          },
          "timeout": {
            "type": "int",
            "default": 10,
            "description": "抓取请求超时时间（秒）"
          }
        }
      }
    }
  },
  "targets": {
    "type": "template_list",
    "description": "推送目标配置",
    "templates": {
      "target": {
        "name": "推送目标",
        "hint": "配置一个消息推送目标",
        "items": {
          "id": {
            "type": "string",
            "default": "",
            "description": "目标唯一 ID"
          },
          "platform": {
            "type": "string",
            "default": "",
            "description": "平台标识，如 qq/telegram"
          },
          "unified_msg_origin": {
            "type": "string",
            "default": "",
            "description": "AstrBot 统一会话标识"
          },
          "enabled": {
            "type": "bool",
            "default": true,
            "description": "是否启用该目标"
          }
        }
      }
    }
  },
  "jobs": {
    "type": "template_list",
    "description": "任务配置",
    "templates": {
      "job": {
        "name": "轮询任务",
        "hint": "一个任务可绑定多个 feed 与多个 target",
        "items": {
          "id": {
            "type": "string",
            "default": "",
            "description": "任务唯一 ID"
          },
          "feed_ids": {
            "type": "list",
            "default": [],
            "description": "关联的 feed ID 列表"
          },
          "target_ids": {
            "type": "list",
            "default": [],
            "description": "关联的 target ID 列表"
          },
          "cron": {
            "type": "string",
            "default": "",
            "description": "cron 表达式（当前版本可留空）"
          },
          "interval_seconds": {
            "type": "int",
            "default": 300,
            "description": "轮询间隔秒数"
          },
          "batch_size": {
            "type": "int",
            "default": 10,
            "description": "每次推送最大条数"
          },
          "enabled": {
            "type": "bool",
            "default": true,
            "description": "是否启用该任务"
          }
        }
      }
    }
  },
  "translation": {
    "type": "object",
    "description": "翻译增强（LLM / Google）",
    "hint": "优先级：LLM -> Google。若仅开启 Google，则直接走 Google 翻译。",
    "items": {
      "llm_enabled": {
        "type": "bool",
        "default": false,
        "description": "启用 LLM 摘要/翻译"
      },
      "llm_provider_id": {
        "type": "string",
        "default": "",
        "_special": "select_provider",
        "description": "LLM 提供商 ID",
        "hint": "留空自动使用当前会话/默认模型；可点击右侧按钮下拉选择。"
      },
      "llm_timeout_seconds": {
        "type": "int",
        "default": 15,
        "description": "LLM 超时（秒）",
        "hint": "超时后若已开启 Google 翻译，将自动回退到 Google。"
      },
      "llm_profile": {
        "type": "string",
        "default": "rss_enrich",
        "description": "LLM profile（高级）",
        "hint": "一般保持默认即可。"
      },
      "max_input_chars": {
        "type": "int",
        "default": 2000,
        "description": "发送给翻译器的最大输入字符数"
      },
      "llm_proxy_mode": {
        "type": "string",
        "default": "system",
        "options": [
          "off",
          "system",
          "custom"
        ],
        "description": "LLM 代理模式（尽力）",
        "hint": "off=不走代理，system=使用系统代理，custom=使用下方代理地址。是否生效取决于所选 Provider。"
      },
      "llm_proxy_url": {
        "type": "string",
        "default": "",
        "description": "LLM 自定义代理地址（尽力）",
        "hint": "示例：http://127.0.0.1:7890（仅 custom 生效，是否生效取决于 Provider）"
      },
      "google_translate_enabled": {
        "type": "bool",
        "default": false,
        "description": "启用 Google 翻译回退/直连"
      },
      "google_translate_api_key": {
        "type": "string",
        "default": "",
        "description": "Google Cloud Translation API Key",
        "obvious_hint": true,
        "hint": "使用 Cloud Translation Basic v2 API Key。"
      },
      "google_translate_target_lang": {
        "type": "string",
        "default": "zh-CN",
        "description": "Google 翻译目标语言",
        "hint": "例如 zh-CN / ja / en"
      },
      "google_translate_timeout_seconds": {
        "type": "int",
        "default": 15,
        "description": "Google 翻译超时（秒）"
      },
      "google_translate_proxy_mode": {
        "type": "string",
        "default": "system",
        "options": [
          "off",
          "system",
          "custom"
        ],
        "description": "Google 翻译代理模式",
        "hint": "off=不走代理，system=使用系统代理，custom=使用下方代理地址"
      },
      "google_translate_proxy_url": {
        "type": "string",
        "default": "",
        "description": "Google 翻译自定义代理地址",
        "hint": "示例：http://127.0.0.1:7890（仅 custom 生效）"
      }
    }
  },
  "dedup_ttl_seconds": {
    "type": "int",
    "default": 604800,
    "description": "RSS 去重记录保留时间（秒），默认 7 天"
  },
  "startup_delay_seconds": {
    "type": "int",
    "default": 45,
    "description": "插件启动后的首次轮询延迟（秒），默认 45 秒"
  },
  "render_mode": {
    "type": "string",
    "default": "text",
    "options": [
      "text",
      "image"
    ],
    "description": "消息渲染模式：text(纯文本+链接) / image(图文卡片)"
  },
  "summary_max_chars": {
    "type": "int",
    "default": 280,
    "description": "摘要最大长度，超出后会截断并附带“查看全文”链接"
  },
  "render_card_template": {
    "type": "object",
    "default": {},
    "description": "图卡/文本渲染模板字段",
    "items": {
      "title": {
        "type": "string",
        "default": "{title}",
        "description": "标题模板，可用变量：title/source/published_at/summary/link"
      },
      "source": {
        "type": "string",
        "default": "{source}",
        "description": "来源模板"
      },
      "published_at": {
        "type": "string",
        "default": "{published_at}",
        "description": "时间模板"
      },
      "summary": {
        "type": "string",
        "default": "{summary}",
        "description": "摘要模板"
      },
      "link_text": {
        "type": "string",
        "default": "查看全文",
        "description": "链接文本模板"
      }
    }
  }
}